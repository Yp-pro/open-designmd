# Choose AI Provider: openrouter, ollama, google, anthropic, openai, custom
AI_PROVIDER=openrouter
AI_MODEL=deepseek/deepseek-chat

# API Keys (fill only the one corresponding to your AI_PROVIDER)
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local Ollama URL (used when AI_PROVIDER=ollama)
# OLLAMA_URL=http://127.0.0.1:11434/api

# Custom local gateway settings (used when AI_PROVIDER=custom)
LOCAL_GATEWAY_URL=http://127.0.0.1:3001/v1
LOCAL_GATEWAY_API_KEY=local-key

# Turso Database Caching (optional)
designmd_TURSO_DATABASE_URL=
designmd_TURSO_AUTH_TOKEN=